# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=SmartAssist USSD
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-in-production-use-random-32-chars

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Docker Compose default — change only if using your own DB
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartassist

# ── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL=300        # USSD session timeout in seconds (5 min)
AI_CACHE_TTL=86400     # Cache AI responses for 24 hours

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001   # cheapest + fastest for USSD
MAX_AI_TOKENS=150

# ── Africa's Talking ─────────────────────────────────────────────────────────
AT_USERNAME=your_username          # "sandbox" for testing
AT_API_KEY=your_api_key
AT_SHORTCODE=SMARTASSIST           # your registered shortcode display name
AT_ENVIRONMENT=sandbox             # "sandbox" or "production"

# ── SMS Settings ─────────────────────────────────────────────────────────────
SMS_ENABLED=true
SMS_CHAR_LIMIT=155   # chars; if AI response > this, offer full answer via SMS
