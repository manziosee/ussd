# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=SmartAssist USSD
APP_VERSION=1.0.0
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-random-32-chars

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Neon (recommended): https://neon.tech — free serverless PostgreSQL
# Docker local:       postgresql+asyncpg://postgres:postgres@localhost:5432/smartassist
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL=300        # USSD session timeout in seconds (5 min)
AI_CACHE_TTL=86400     # Cache AI responses for 24 hours
# If Redis is unavailable the server auto-falls back to in-memory fakeredis (dev mode)

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
MAX_AI_TOKENS=150

# ── Africa's Talking ─────────────────────────────────────────────────────────
AT_USERNAME=sandbox               # use "sandbox" for testing
AT_API_KEY=your_api_key
AT_SHORTCODE=SMARTASSIST
AT_ENVIRONMENT=sandbox            # "sandbox" | "production"

# Secret token appended to your AT callback URL:
#   https://yourserver.com/ussd?token=<AT_WEBHOOK_TOKEN>
# Configure the same URL in your AT USSD channel settings.
# Leave empty to skip token check (sandbox / local dev).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AT_WEBHOOK_TOKEN=

# ── Admin API ─────────────────────────────────────────────────────────────────
# Required header on every /admin/* request:  X-Admin-Key: <ADMIN_API_KEY>
# Leave empty → admin API returns 503 (disabled) until you set this.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── SMS Settings ─────────────────────────────────────────────────────────────
SMS_ENABLED=true
SMS_CHAR_LIMIT=155   # chars; if AI response > this, offer full answer via SMS
