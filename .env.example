# ════════════════════════════════════════════════════════════════════
#  SmartAssist USSD — Environment Variables
#  Copy this file to .env and fill in the real values.
#  NEVER commit the real .env — it is gitignored.
# ════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SmartAssist USSD
APP_VERSION=1.0.0
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver required (postgresql+asyncpg:// scheme).
# Neon free tier: https://neon.tech  |  Local Docker: see docker-compose.yml
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Redis ──────────────────────────────────────────────────────────────────────
# If Redis is unavailable the app auto-falls-back to in-memory fakeredis.
REDIS_URL=redis://localhost:6379/0
SESSION_TTL=300       # USSD session timeout in seconds
AI_CACHE_TTL=86400    # Cache AI responses for 24 hours

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# Free tier available at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant   # fastest; swap to llama-3.3-70b-versatile for higher quality
MAX_AI_TOKENS=150

# ── USSD shortcode ─────────────────────────────────────────────────────────────
# The shortcode your USSD aggregator assigned you (e.g. *123# or *384*72275#).
# Used in SMS footers and tip messages.
USSD_SHORTCODE=*123#

# ── USSD webhook security ──────────────────────────────────────────────────────
# AT_API_KEY verifies the X-AT-Hash HMAC on USSD callbacks.
# AT_WEBHOOK_TOKEN is appended to your callback URL: /ussd?token=<value>
# Leave both empty for local dev / sandbox (verification is skipped).
AT_API_KEY=
AT_WEBHOOK_TOKEN=

# ── Admin API ──────────────────────────────────────────────────────────────────
# Protects all /admin/* routes.
# Header: X-Admin-Key: <value>   |   Browser: /admin/dashboard?key=<value>
# Leave blank → admin API returns 503 until set.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── Cron (daily tip broadcast) ─────────────────────────────────────────────────
# Protects POST /cron/daily-tips?secret=<value>
# Leave blank → endpoint returns 403 (disabled).
CRON_SECRET=

# ── SMS ────────────────────────────────────────────────────────────────────────
SMS_ENABLED=true
SMS_CHAR_LIMIT=155    # responses longer than this are offered via SMS

# ── SMS Gateway (Jasmin-backed microservice on port 8001) ──────────────────────
# Docker internal: http://sms-gateway:8001   |   Local dev: http://localhost:8001
SMS_GATEWAY_URL=http://sms-gateway:8001

# ── SMS Gateway internals (SMS_GW_ prefix — read by sms_gateway/ service) ──────
SMS_GW_JASMIN_HOST=jasmin
SMS_GW_JASMIN_HTTP_PORT=1401
SMS_GW_JASMIN_USERNAME=admin
SMS_GW_JASMIN_PASSWORD=admin
SMS_GW_DEFAULT_SENDER_ID=SmartAssist

# Country dialing prefix → Jasmin connector CID (JSON).
# Leave empty {} to use Jasmin's own MT routing rules (recommended global default).
# Add entries only to override routing for specific prefixes:
#   SMS_GW_CONNECTOR_MAP_JSON={"254":"ke","234":"ng","91":"in"}
SMS_GW_CONNECTOR_MAP_JSON={}
