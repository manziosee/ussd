# ════════════════════════════════════════════════════════════════════
#  SmartAssist USSD — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit the real .env file — it is gitignored.
# ════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SmartAssist USSD
APP_VERSION=1.0.0
DEBUG=false

# Secret key used for any future signed tokens / cookies.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-random-32-chars

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# asyncpg driver required — URL must use the postgresql+asyncpg:// scheme.
# For Neon / Supabase use the pooler endpoint (faster, cheaper connections).
#
# Local Docker Compose:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartassist
#
# Neon (recommended for production):
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Cache (Redis) ────────────────────────────────────────────────────────────
# If Redis is unavailable the app automatically falls back to in-memory
# fakeredis so it still runs in dev with zero infrastructure.
REDIS_URL=redis://localhost:6379/0

# USSD session timeout in seconds (Africa's Talking enforces ~5 min max)
SESSION_TTL=300

# How long to cache identical AI responses — 24 h = zero repeat cost
AI_CACHE_TTL=86400

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# claude-haiku-4-5-20251001 is cheapest + fastest; ideal for USSD latency.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Hard cap on output tokens per AI call (keeps response costs predictable)
MAX_AI_TOKENS=150

# ── Africa's Talking ─────────────────────────────────────────────────────────
# Create a free sandbox account at https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key

# The shortcode shown to users (sandbox default is 12345)
AT_SHORTCODE=12345

# "sandbox" or "production"
AT_ENVIRONMENT=sandbox

# ── Webhook security (two layers) ────────────────────────────────────────────
#
# Layer 1 — URL token
#   Configure AT to POST to:  https://yourserver.com/ussd?token=<this value>
#   Requests without a matching token are rejected with HTTP 403.
#   Leave blank to disable (safe for local dev / ngrok / sandbox).
#   Generate: python -c "import secrets; print(secrets.token_hex(16))"
AT_WEBHOOK_TOKEN=

# Layer 2 — HMAC-SHA256 body signing (X-AT-Hash header)
#   Verified automatically when AT_API_KEY is set and AT_ENVIRONMENT=production.
#   Skipped in sandbox (AT does not sign sandbox callbacks).
#   No extra variable needed — uses AT_API_KEY as the HMAC secret.

# ── Admin API ─────────────────────────────────────────────────────────────────
# Protects all /admin/* routes.
#
# API clients (curl, Postman):  pass as header  X-Admin-Key: <value>
# Browser (dashboard):          pass as query   /admin/dashboard?key=<value>
#
# Leave blank → entire admin API returns 503 until this is set.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── SMS ───────────────────────────────────────────────────────────────────────
# When true, AI responses longer than SMS_CHAR_LIMIT are sent in full via SMS.
# Requires AT_API_KEY to be set.
SMS_ENABLED=true

# If an AI response exceeds this many characters, it is truncated on the USSD
# screen and the full answer is delivered via SMS (unless user opted out).
SMS_CHAR_LIMIT=155
